  "keyFeatures": [
    "Real-time terminal-based messaging",
    "Channel and direct message support",
    "Embedded AI agents (Claude)",
    "Live presence and typing indicators",
    "Browser-based OAuth authentication",
    "Keyboard-driven navigation",
    "Channel administration and invites",
    "Cross-platform native binaries"
  ],
  "publicApiSurface": [
    "/claude - Enter Claude AI agent mode",
    "/exit - Exit current agent mode",
    "/invite <username> - Invite user to channel",
    "/remove <username> - Remove user from channel",
    "/invite_link - Create channel invite link",
    "groupchat - Main CLI command",
    "GROUPCHAT_CONSOLE_URL - Environment variable for console URL",
    "GROUPCHAT_WS_URL - Environment variable for WebSocket URL",
    "GROUPCHAT_PROFILE - Environment variable for profile selection",
    "GROUPCHAT_DEBUG - Environment variable for debug mode"
  ]
